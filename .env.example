# MongoDB
DATABASE_URL=mongodb://localhost:27017/healthbot
# or Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/healthbot?retryWrites=true&w=majority

# JWT — keep this secret and random in production
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (for verifying Google sign-in credentials)
GOOGLE_CLIENT_ID=

# Google Gemini
GEMINI_API_KEY=
# Optional — multiple API keys (comma-separated). If one key fails all models, the next key is tried.
# Takes precedence over GEMINI_API_KEY when set (otherwise GEMINI_API_KEY may itself be comma-separated).
# GEMINI_API_KEYS=key1,key2,key3

# Optional — full priority list (comma-separated). Tries each model until one succeeds.
# Defaults favor high RPM/RPD models (3.1 Flash-Lite preview → Gemma → 3 Flash preview → 2.5 Flash-Lite → 2.5 Flash).
# GEMINI_MODEL_ORDER=gemini-3.1-flash-lite-preview,gemma-3-4b-it,gemini-3-flash-preview,gemini-2.5-flash-lite,gemini-2.5-flash
# Legacy: single model + one fallback (only if GEMINI_MODEL_ORDER is unset)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite

# Groq (OpenAI-compatible API; used if Gemini fails or when listed first in AI_PROVIDER_ORDER)
GROQ_API_KEY=
# Optional — comma-separated model ids (default: llama-3.1-8b-instant → llama-3.3-70b-versatile → qwen/qwen3-32b)
# GROQ_MODEL_ORDER=llama-3.1-8b-instant,llama-3.3-70b-versatile

# Provider order when both keys are set: try each until one succeeds (429 uses retry-after, then next model / next provider).
# AI_PROVIDER_ORDER=gemini,groq

# Knowledge database (MongoDB collection `knowledgeentries`) — used when every AI provider fails.
# On first API startup, if the collection is empty, 100+ bundled topics are inserted automatically.
# Manual seed / replace: npm run seed:knowledge   |   npm run seed:knowledge:force
# After upgrading bundled knowledge text, run seed:knowledge:force once to refresh MongoDB.

# Server
PORT=5000
FRONTEND_URL=http://localhost:3000
